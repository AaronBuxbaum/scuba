{
  "permissions": {
    "allow": [
      "ScheduleWakeup",
      "mcp__claude_code_remote__unsubscribe_pr_activity",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm format)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm test:watch)",
      "Bash(pnpm e2e)",
      "Bash(pnpm check)",
      "Bash(pnpm build)",
      "Bash(pnpm dev)",
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(node scripts/screenshot.mjs:*)",
      "Bash(npx playwright test:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "git config user.name \"Aaron Buxbaum\" && git config user.email \"aaronbuxbaum@gmail.com\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "[ -d node_modules ] || pnpm install --frozen-lockfile",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
