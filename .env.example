# Local dev and tests need none of this — no DATABASE_URL means src/db/client.ts
# falls back to an embedded PGlite database, auto-migrated and auto-seeded.

# Production only. Vercel's Neon integration injects these automatically into
# the deployed environment; nothing to set by hand there. Only fill this file
# in if you're pointing a local run at a real Neon database on purpose.
# Pooled (PgBouncer) connection — used at request time (src/db/client.ts).
# If set manually, use sslmode=verify-full in the URL; the app normalizes legacy
# sslmode=require/prefer/verify-ca values to that explicit mode at runtime and
# during migrations.
DATABASE_URL=

# Direct/unpooled connection — used for schema migrations (`pnpm db:migrate`),
# since DDL over a transaction-mode pooler is unreliable. Neon calls this the
# "unpooled" connection string; falls back to DATABASE_URL if unset.
DATABASE_URL_UNPOOLED=

# Required in production (NextAuth fails loudly without it there); dev/test
# fall back to a hardcoded non-production secret. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Transactional email through Resend. Use a verified Resend sender; the friendly
# sender name is supported (for example, "Blue Mantis <bookings@example.com>").
# Keep both values server-only — neither may use a NEXT_PUBLIC_ prefix.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Canonical public origin used only to build private waiver-completion links.
# Set the deployed custom domain, including https:// and without a trailing slash.
APP_HOST=

# Certification review is manual: staff look a C-card number up with the issuing
# agency and mark it certified. There is no automated agency-verification
# integration and no environment configuration for one.

# Stripe Connect: shops bring their own Standard Stripe account (docs ADR
# 20260719-stripe-connect-orders). STRIPE_SECRET_KEY is the *platform*
# account's secret key — once a shop completes OAuth, this key can act on its
# behalf via a Stripe-Account header, so no per-shop credential is stored.
# STRIPE_CONNECT_CLIENT_ID comes from the platform's Connect settings
# (https://dashboard.stripe.com/settings/connect). Without both, the connect
# button and order creation report not_configured rather than half-working.
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=

# Signing secret for the Connect webhook endpoint (/api/webhooks/stripe),
# configured in the Stripe dashboard against that URL with "listen to events
# on Connected accounts" enabled. Without it, orders still work but their
# paid/void status only updates via the manual "Refresh status" action.
STRIPE_WEBHOOK_SECRET=

# SMS / WhatsApp notifications through Twilio (docs ADR
# 20260721-sms-whatsapp-notifications). ACCOUNT_SID + AUTH_TOKEN authorize the
# account; each FROM enables its channel independently — set only SMS_FROM for
# texts, only WHATSAPP_FROM for WhatsApp, or both. A channel with no FROM (or no
# credentials at all) reports not_configured rather than sending. Numbers are
# E.164 (e.g. +13055550100); the WhatsApp sender is a WhatsApp-enabled number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Scheduled pre-trip reminders (docs ADR 20260721-scheduled-reminder-cadence).
# Vercel Cron calls GET /api/cron/reminders daily with this as a bearer token
# (the Hobby plan caps crons at daily; the cadence buckets are >=24h wide so a
# daily run never misses one). The endpoint is unavailable (503) until this is
# set, so nothing can trigger reminder sends by accident.
# Generate with: openssl rand -base64 32
CRON_SECRET=
